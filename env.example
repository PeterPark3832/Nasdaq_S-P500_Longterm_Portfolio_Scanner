# =============================================
# 미국주식 장기 투자 스캐너 v4.0 환경변수
# =============================================
# 이 파일을 .env로 복사 후 실제 값으로 채우세요
# cp .env.example .env

# ── 텔레그램 봇 토큰 ──────────────────────────
# BotFather에서 발급받은 봇 토큰
TELEGRAM_TOKEN=your_bot_token_here

# ── 채팅방 ID ──────────────────────────────────
# 포럼(Forum/Topic) 슈퍼그룹은 앞에 -100 붙임
# https://t.me/c/XXXXXXXXXX/4/5 → -100XXXXXXXXXX
# 여러 개면 콤마 구분: -100XXXXXXXXXX,987654321
TELEGRAM_CHAT_IDS=-100XXXXXXXXXX,YYYYYYYYY

# ── 토픽(Topic) ID ─────────────────────────────
# 포럼 그룹에서 특정 토픽으로 보낼 때 사용
# https://t.me/c/XXXXXXXXXX/4/5 → URL 세 번째 숫자 = 4
# 일반 채팅방이면 이 줄 삭제 또는 비워두기
# 주석(#) 달아도 숫자만 파싱하므로 안전
TELEGRAM_TOPIC_ID=4  # 미국주식 장기투자 토픽
